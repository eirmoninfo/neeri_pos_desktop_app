VITE_API_BASE_URL=http://127.0.0.1:8000

# Pusher Cloud (Hostinger shared hosting compatible)
VITE_PUSHER_KEY=
VITE_PUSHER_CLUSTER=ap2
# Leave empty for Pusher Cloud. Only set for local Soketi.
# VITE_WS_HOST=127.0.0.1
# VITE_WS_PORT=6001
# VITE_WS_SCHEME=http

# Optional: invoice print view (Invoice → Print)
# VITE_INVOICE_SALON_LOGO=Your Salon Name
# VITE_INVOICE_ADDRESS_LINE1=Shop 131, ...
# VITE_INVOICE_ADDRESS_LINE2=(Near Nando's, ...)
# VITE_INVOICE_POWERED_BY=Your Company

# VITE_INVOICE_LOGO_URL=/assets/images/logo.png

# Optional: POS /invoices/save CSRF token
# VITE_POS_CSRF_TOKEN=TO9aMQPY8Fa3x9ilKma00AI6mdEjQR2iViayQvKS

# Optional: receipt printer (exact name from OS). Auto-detected if omitted.
# VITE_POS_RECEIPT_PRINTER=EPSON_TM_T88
# Optional: ESC/POS cash drawer pulse (hex). Default: 1B700019FA
# VITE_POS_DRAWER_PULSE_HEX=1B700019FA

# Optional: Electron auto-update feed URL (generic provider)
# Example: https://your-domain.com/updates
# AUTO_UPDATE_URL=

# Required for private GitHub update repo (electron-updater).
# Create a fine-grained or classic PAT with access to eirmoninfo/neeri_pos_desktop_app (Contents: Read).
# Do NOT commit real tokens. Prefer making releases public instead of shipping tokens to clients.
# Required only when publishing releases (npm run release:win / release:mac)
# GH_TOKEN=your_github_token_here
# GITHUB_TOKEN=your_github_token_here
